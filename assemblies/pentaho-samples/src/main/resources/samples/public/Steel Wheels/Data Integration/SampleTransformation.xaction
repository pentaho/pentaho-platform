<action-sequence> 
  <name>SampleTransformation.xaction</name>
  <title>%title</title>
  <version>1</version>
  <logging-level>debug</logging-level>
  <documentation> 
    <author>Gretchen Moran</author>  
    <description>%description</description>  
    <help>%help</help>  
    <result-type>rule</result-type>  
    <icon>HelloETL.png</icon> 
  </documentation>

  <inputs/>

  <outputs> 
    <rule-result type="result-set"/>
  </outputs>

  <resources> 
    <transformation-file> 
      <solution-file> 
        <location>sample.ktr</location>  
        <mime-type>text/xml</mime-type> 
      </solution-file> 
    </transformation-file> 
  </resources>
  
  <actions> 
    <action-definition> 
      <component-name>KettleComponent</component-name>
      <action-type>Execute Kettle Transformation</action-type>
      <action-inputs/>
      <action-resources> 
        <transformation-file type="resource"/> 
      </action-resources>
      <action-outputs> 
        <transformation-output type="result-set" mapping="rule-result"/> 
      </action-outputs>
      <component-definition> 
        <importstep>XML Output</importstep> 
      </component-definition> 
    </action-definition>
 
  </actions> 
</action-sequence>